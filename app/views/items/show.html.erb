<!-- BACK LINK -->
<div class="back-link">
  <a href="/">← Back to Collection</a>
</div>

<!-- ITEM DETAIL -->
<section class="item-detail">
  <div class="item-detail-grid">

    <!-- LEFT: IMAGE -->
    <div class="item-detail-image">
      <img src="<%= @item.image_url %>" alt="<%= @item.title %>">
      <span class="status-badge <%= @item.status %>">
        <%= @item.status.gsub("_", " ").capitalize %>
      </span>
    </div>

    <!-- RIGHT: INFO -->
    <div class="item-detail-info">
      <p class="item-collection"><%= @item.collection %></p>
      <h1><%= @item.title %></h1>
      <p class="item-description"><%= @item.description %></p>

      <div class="item-source">
  <p>View original on <a href="<%= @item.source_url %>" target="_blank">CORE Scholar →</a></p>
      </div>
    </div>

  </div>
</section>

<!-- TRANSCRIPTION FORM -->
<section class="transcription-section">
  <h2>SUBMIT A TRANSCRIPTION</h2>
  <p class="transcription-intro">Read the document image carefully and type out the full text below. Please transcribe exactly what you see, including any spelling or punctuation from the original.</p>

  <% if notice %>
    <div class="alert success"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert error"><%= alert %></div>
  <% end %>

  <%= form_with url: item_transcriptions_path(@item), method: :post do |f| %>
    <div class="form-group">
      <%= f.label :transcriber_name, "Your Name" %>
      <%= f.text_field :transcriber_name, placeholder: "Enter your name" %>
    </div>
    <div class="form-group">
      <%= f.label :content, "Transcription" %>
      <%= f.text_area :content, rows: 10, placeholder: "Type the full text of the document here..." %>
    </div>
    <%= f.submit "Submit Transcription", class: "btn-submit" %>
  <% end %>
</section>

<!-- EXISTING TRANSCRIPTIONS -->
<% if @transcriptions.any? %>
<section class="existing-transcriptions">
  <h2>SUBMITTED TRANSCRIPTIONS (<%= @transcriptions.count %>)</h2>
  <% @transcriptions.each do |t| %>
    <div class="transcription-entry">
      <div class="transcription-header">
        <span class="transcriber-name"><%= t.transcriber_name %></span>
        <span class="transcription-date"><%= t.created_at.strftime("%B %d, %Y") %></span>
      </div>
      <p class="transcription-content"><%= t.content %></p>
    </div>
  <% end %>
</section>
<% end %>
