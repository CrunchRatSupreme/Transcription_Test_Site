<!-- BACK LINK -->
<div class="back-link">
  <a href="/">← Back to Collection</a>
</div>

<!-- ITEM DETAIL -->
<section class="item-detail">
  <div class="item-detail-grid">

    <!-- LEFT: IMAGE -->
    <div class="item-detail-image">
      <img src="<%= @item.image_url %>" alt="<%= @item.title %>">
      <span class="status-badge <%= @item.status %>">
        <%= @item.status.gsub("_", " ").capitalize %>
      </span>
    </div>

    <!-- RIGHT: INFO -->
    <div class="item-detail-info">
      <p class="item-collection"><%= @item.collection %></p>
      <h1><%= @item.title %></h1>
      <p class="item-description"><%= @item.description %></p>

      <div class="item-source">
        <p>View document on <a href="<%= @item.source_url %>" target="_blank">CORE Scholar</a></p>
      </div>

      <div class="claim-section">

        <% if @item.status == "available" %>
          <div class="claim-form">
            <h4>Claim this item to transcribe it</h4>
            <p>Click below to let others know you are working on this letter.</p>
            <button class="btn-claim" onclick="document.getElementById('claim-modal').style.display='flex'">
              Claim Item
            </button>
          </div>
          <div id="claim-modal" class="modal-overlay" style="display:none;">
            <div class="modal-box">
              <button class="modal-close" onclick="document.getElementById('claim-modal').style.display='none'">X</button>
              <h3>Claim This Item</h3>
              <p class="modal-item-title"><%= @item.title %></p>
              <%= form_with url: claim_item_path(@item), method: :post do |f| %>
                <div class="form-group">
                  <%= f.label :claimed_first_name, "First Name" %>
                  <%= f.text_field :claimed_first_name, placeholder: "Enter your first name", required: true %>
                </div>
                <div class="form-group">
                  <%= f.label :claimed_last_name, "Last Name" %>
                  <%= f.text_field :claimed_last_name, placeholder: "Enter your last name", required: true %>
                </div>
                <div class="form-group">
                  <%= f.label :claimed_email, "Email Address" %>
                  <%= f.email_field :claimed_email, placeholder: "Enter your email", required: true %>
                </div>
                <div class="form-group">
                  <%= f.label :item_title, "Item to Transcribe" %>
                  <%= f.text_field :item_title, value: @item.title, disabled: true, class: "input-disabled" %>
                </div>
                <%= f.submit "Confirm Claim", class: "btn-submit" %>
              <% end %>
            </div>
          </div>

        <% elsif @item.status == "in_progress" && @item.claimed_by.present? %>
          <div class="claimed-info">
            <p class="claimed-by">Claimed by <strong><%= @item.claimed_by %></strong></p>
            <p class="claimed-at">Claimed on <%= @item.claimed_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            <button class="btn-release" onclick="document.getElementById('release-modal').style.display='flex'">
              Release Claim
            </button>
          </div>
          <div id="release-modal" class="modal-overlay" style="display:none;">
            <div class="modal-box">
              <button class="modal-close" onclick="document.getElementById('release-modal').style.display='none'">X</button>
              <h3>Release This Claim</h3>
              <p class="modal-item-title"><%= @item.title %></p>
              <p style="font-size:14px; color:#666; font-family:Arial,sans-serif; margin-bottom:24px;">
                Enter the admin password to release this claim and make it available again.
              </p>
              <%= form_with url: release_item_path(@item), method: :post do |f| %>
                <div class="form-group">
                  <%= f.label :admin_password, "Admin Password" %>
                  <%= f.password_field :admin_password, placeholder: "Enter admin password", required: true %>
                </div>
                <%= f.submit "Confirm Release", class: "btn-submit" %>
              <% end %>
            </div>
          </div>

        <% elsif @item.status == "completed" %>
          <div class="completed-info">
            <p>This item has been fully transcribed.</p>
          </div>

        <% end %>
      </div>

    </div>
  </div>
</section>

<!-- TRANSCRIPTION FORM -->
<section class="transcription-section">
  <h2>CONTACT US</h2>
  <p class="transcription-intro">Ask a question or submit a transcription. If submitting a transcription, read the document image carefully and type out the full text in a Word document. Please transcribe exactly what you see, including any spelling or punctuation from the original.</p>

  <% if notice %>
    <div class="alert success"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="alert error"><%= alert %></div>
  <% end %>

  <%= form_with url: item_transcriptions_path(@item), method: :post, multipart: true do |f| %>
    <div class="form-group">
      <%= f.label :transcriber_name, "Your Name" %>
      <%= f.text_field :transcriber_name, placeholder: "Enter your name" %>
    </div>
    <div class="form-group">
      <%= f.label :transcriber_email, "Your Email" %>
      <%= f.email_field :transcriber_email, placeholder: "Enter your email" %>
    </div>
     <div class="form-group">
      <%= f.label :document, "Upload Document" %>
      <p class="upload-hint">You may upload a Word document or PDF of your transcription.</p>
      <%= f.file_field :document, accept: ".pdf,.doc,.docx" %>
    </div>
    <div class="form-group">
      <%= f.label :content, "Message" %>
      <%= f.text_area :content, rows: 10, placeholder: "Type your message here..." %>
    </div>
   
    <%= f.submit "Submit Transcription", class: "btn-submit" %>
  <% end %>
</section>

<!-- EXISTING TRANSCRIPTIONS -->
<% if @transcriptions.any? %>
  <section class="existing-transcriptions">
    <h2>SUBMITTED TRANSCRIPTIONS (<%= @transcriptions.count %>)</h2>
    <% @transcriptions.each do |t| %>
      <div class="transcription-entry">
        <div class="transcription-header">
          <span class="transcriber-name"><%= t.transcriber_name %></span>
          <span class="transcription-date"><%= t.created_at.strftime("%B %d, %Y") %></span>
        </div>
        <p class="transcription-content"><%= t.content %></p>
      </div>
    <% end %>
  </section>
<% end %>
